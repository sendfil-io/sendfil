VITE_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id
VITE_DEFAULT_NETWORK=mainnet

# FEVM RPC
VITE_FEVM_RPC_URL_MAINNET=https://api.node.glif.io/rpc/v1
VITE_FEVM_RPC_URL_CALIBRATION=https://api.calibration.node.glif.io/rpc/v1

# Lotus RPC
VITE_LOTUS_RPC_URL_MAINNET=https://api.node.glif.io/rpc/v1
VITE_LOTUS_RPC_FALLBACK_MAINNET=https://rpc.node.glif.io/rpc/v1
VITE_LOTUS_RPC_URL_CALIBRATION=https://api.calibration.node.glif.io/rpc/v1
VITE_LOTUS_RPC_FALLBACK_CALIBRATION=https://api.calibration.node.glif.io/rpc/v1
VITE_LOTUS_RPC_TIMEOUT_MS=10000

# Explorer
VITE_FILFOX_BASE_MAINNET=https://filfox.info/en/message/
VITE_FILFOX_BASE_CALIBRATION=https://calibration.filfox.info/en/message/

# Standard path contracts
VITE_MULTICALL3_ADDRESS_MAINNET=0xcA11bde05977b3631167028862bE2a173976CA11
VITE_MULTICALL3_ADDRESS_CALIBRATION=0xcA11bde05977b3631167028862bE2a173976CA11
VITE_FILFORWARDER_ADDRESS_MAINNET=0x2b3ef6906429b580b7b2080de5ca893bc282c225
VITE_FILFORWARDER_ADDRESS_CALIBRATION=0x2b3ef6906429b580b7b2080de5ca893bc282c225

# ThinBatch stays optional
VITE_THINBATCH_ADDRESS_MAINNET=
VITE_THINBATCH_ADDRESS_CALIBRATION=

# Mainnet fee policy
VITE_FEE_ENABLED_MAINNET=true
VITE_FEE_PERCENT_MAINNET=1
VITE_FEE_SPLIT_MAINNET=0.5
VITE_FEE_ADDR_A_MAINNET=f1feeaddressA...
VITE_FEE_ADDR_B_MAINNET=f1feeaddressB...

# Calibration fee policy
VITE_FEE_ENABLED_CALIBRATION=false
VITE_FEE_PERCENT_CALIBRATION=1
VITE_FEE_SPLIT_CALIBRATION=0.5
VITE_FEE_ADDR_A_CALIBRATION=
VITE_FEE_ADDR_B_CALIBRATION=

# Optional E2E helpers
VITE_E2E_MOCK_WALLET=false
VITE_E2E_SKIP_GAS_ESTIMATION=false
VITE_E2E_SEND_DELAY_MS=3000
VITE_E2E_CHAIN_ID=314
